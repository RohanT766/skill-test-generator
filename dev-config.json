{
  "$schema": "./src/skill_test_generator/schema.json",

  "custom_skills": [
    {
      "name": "Navigate paginated list exhaustively to find global extremum",
      "description": "User must click through all pages of a paginated list to find the row with the highest or lowest value"
    }
  ],
  "max_skills": 20,
  "specs_per_skill": 1,

  "stage": null,
  "concurrency": 4,

  "template_name": "sohan",
  "sim_name_prefix": "skill-test",
  "design_model": "claude-opus-4-6",

  "coder_agent": {
    "package": "claude-code:latest",
    "config": {
      "model_name": "claude-opus-4-6",
      "max_turns": 50
    }
  },
  "codegen_verify_port": 4000,

  "eval_agent_model": "amazon/nova-act",
  "eval_agent": null,
  "eval_max_turns": 99,
  "eval_display_width": 1600,
  "eval_display_height": 813,
  "record_sessions": true,

  "base_artifact_id": "",
  "plato_api_url": "https://plato.so",
  "chronos_url": "https://chronos.plato.so",

  "plato_api_key": "${PLATO_API_KEY}",
  "anthropic_api_key": "${ANTHROPIC_API_KEY}",
  "aws_access_key_id": "",
  "aws_secret_access_key": "",
  "aws_session_token": "",
  "nova_act_api_key": "",
  "nova_act_workflow_name": "plato-cua-benchmark",

  "cua_world_package": "plato-world-cua-benchmark:3.1.58",
  "cua_agent_package": "computer-use-agent:3.2.35"
}
