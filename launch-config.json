{
  "world": {
    "package": "plato-world-skill-test-generator:0.4.30",
    "runtime": {
      "type": "vm",
      "vm": {
        "cpus": 2,
        "memory": 4096,
        "disk": 20480,
        "timeout": 14400
      }
    },
    "config": {
      "s3_skills": [
        "Exhaustively paginate list before identifying extremum record",
        "Distinguish between similarly-named record types in navigation menus"
      ],
      "specs_per_skill": 2,
      "design_concurrency": 4,
      "max_skills": 2,
      "output_tasks_per_variant": 2,
      "mutation_tasks_per_variant": 0,
      "sessions_per_testcase": 3,
      "run_concurrency": 10,
      "vm_concurrency": 4,
      "pipeline_vm_cpus": 2,
      "pipeline_vm_memory": 4096,
      "eval_agent_model": "amazon/nova-act",
      "cua_world_package": "plato-world-cua-benchmark:3.6.1",
      "cua_agent_package": "computer-use-agent:3.2.61",
      "coder_agent": {
        "package": "claude-code:latest",
        "config": {
          "model_name": "claude-opus-4-6",
          "max_turns": 150,
          "anthropic_api_key": "${ANTHROPIC_API_KEY}"
        }
      },
      "aws_access_key_id": "${AWS_ACCESS_KEY_ID}",
      "aws_secret_access_key": "${AWS_SECRET_ACCESS_KEY}",
      "aws_session_token": "${AWS_SESSION_TOKEN}",
      "anthropic_api_key": "${ANTHROPIC_API_KEY}",
      "plato_api_key": "${PLATO_API_KEY}",
      "nova_act_workflow_name": "${NOVA_ACT_WORKFLOW_NAME}",
      "autoverify": true,
      "autoverify_sessions": 4,
      "autoverify_model": "anthropic/claude-opus-4-6",
      "hillclimb": {
        "enabled": true,
        "total_failures": 1,
        "max_retries": 2
      },
      "dry_run": false
    }
  },
  "retry": {
    "max_retries": 3
  }
}
