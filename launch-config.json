{
  "world": {
    "package": "plato-world-skill-test-generator:0.3.40",
    "runtime": {
      "type": "vm",
      "vm": {
        "cpus": 2,
        "memory": 4096,
        "disk": 10240,
        "timeout": 14400
      }
    },
    "config": {
      "s3_skills": [
        "Exhaustively paginate list before identifying extremum record",
        "Resolve truncated text in data grid cells before using value",
        "Aggregate values across data grid rows before selecting maximum",
        "Account for pagination when counting rows in data grid"
      ],
      "specs_per_skill": 3,
      "concurrency": 6,
      "max_skills": 4,
      "output_tasks_per_variant": 3,
      "mutation_tasks_per_variant": 0,
      "sessions_per_testcase": 3,
      "run_concurrency": 30,
      "max_parallel_pipelines": 10,
      "pipeline_vm_cpus": 2,
      "pipeline_vm_memory": 4096,
      "eval_agent_model": "amazon/nova-act",
      "cua_world_package": "plato-world-cua-benchmark:3.3.22",
      "cua_agent_package": "computer-use-agent:3.2.48",
      "coder_agent": {
        "package": "claude-code:latest",
        "config": {
          "model_name": "claude-opus-4-6",
          "max_turns": 150,
          "anthropic_api_key": "${ANTHROPIC_API_KEY}"
        }
      },
      "aws_access_key_id": "${AWS_ACCESS_KEY_ID}",
      "aws_secret_access_key": "${AWS_SECRET_ACCESS_KEY}",
      "aws_session_token": "${AWS_SESSION_TOKEN}",
      "anthropic_api_key": "${ANTHROPIC_API_KEY}",
      "plato_api_key": "${PLATO_API_KEY}",
      "nova_act_workflow_name": "${NOVA_ACT_WORKFLOW_NAME}"
    }
  },
  "retry": {
    "max_retries": 3
  }
}
